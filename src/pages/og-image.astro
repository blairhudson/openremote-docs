---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>OpenRemote OG Image</title>
  </head>
  <body class="og-page">
    <main class="og-canvas" aria-label="OpenRemote social preview">
      <section class="og-panel">
        <img class="og-wordmark" src="/openremote-wordmark.svg" alt="OpenRemote" />
        <p class="og-kicker">Remote for OpenCode</p>
        <h1>Control desktop coding sessions from your phone.</h1>
        <p class="og-copy">Chat, run shell commands, switch models, and approve permissions over your local network.</p>
        <div class="og-feature-row" aria-hidden="true">
          <span>TUI Sidebar</span>
          <span>QR Code Connect</span>
          <span>Keep Awake</span>
        </div>
      </section>
      <div class="og-logo-mark" aria-hidden="true">
        <img src="/openremote-icon.svg" alt="" />
      </div>
    </main>
  </body>
</html>
