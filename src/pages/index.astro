---
import "../styles/global.css";

const repoUrl = "https://github.com/blairhudson/openremote";
const iosBetaUrl = "#ios-beta";
const androidBetaUrl = "#android-beta";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="OpenRemote is a mobile companion for OpenCode. Connect to desktop sessions, chat, run shell commands, and approve permissions from your phone." />
    <link rel="icon" type="image/svg+xml" href="/openremote-icon.svg" />
    <link rel="apple-touch-icon" href="/openremote-icon.svg" />
    <title>OpenRemote</title>
  </head>
  <body>
    <main class="page-shell">
      <nav class="topbar" aria-label="Primary navigation">
        <a class="brand" href="#top" aria-label="OpenRemote home">
          <img src="/openremote-wordmark.svg" alt="openremote" />
        </a>
        <div class="nav-links">
          <a href="#beta">beta</a>
          <a href="#help">help</a>
          <a href={repoUrl}>github</a>
        </div>
      </nav>

      <section id="top" class="hero">
        <div class="hero-copy">
          <p class="eyebrow">OpenCode in your pocket</p>
          <h1>Control desktop coding sessions from your phone.</h1>
          <p class="lede">OpenRemote connects to OpenCode over your local network so you can chat, switch models, run shell commands, and approve permissions without staying at your desk.</p>
          <div class="actions" aria-label="Primary actions">
            <a class="button primary" href={iosBetaUrl}>iOS beta</a>
            <a class="button" href={androidBetaUrl}>Android beta</a>
            <a class="button ghost" href={repoUrl}>GitHub repo</a>
          </div>
          <div class="terminal-note" aria-label="Quick start command">
            <span class="prompt">$</span>
            <code>opencode --mdns</code>
          </div>
        </div>

        <div class="device-frame" aria-label="OpenRemote app video preview">
          <div class="phone-shell">
            <div class="phone-status">
              <span>openremote</span>
              <span>connected</span>
            </div>
            <video class="app-video" autoplay muted loop playsinline controls poster="/openremote-icon.svg">
              <source src="/app-demo.mp4" type="video/mp4" />
            </video>
            <div class="video-fallback">
              <strong>app video soon</strong>
              <span>drop `app-demo.mp4` into `public/`</span>
            </div>
          </div>
        </div>
      </section>

      <section class="feature-grid" aria-label="OpenRemote features">
        <article>
          <span class="glyph">/</span>
          <h2>Session control</h2>
          <p>Open existing sessions, send prompts, switch Build or Plan, and keep context visible while OpenCode streams.</p>
        </article>
        <article>
          <span class="glyph">$</span>
          <h2>Shell from mobile</h2>
          <p>Swipe to terminal input, run shell commands, and keep output inside the main transcript.</p>
        </article>
        <article>
          <span class="glyph">?</span>
          <h2>Permission approvals</h2>
          <p>Approve once, approve always, or reject with fallback instructions from phone.</p>
        </article>
      </section>

      <section id="beta" class="split-section">
        <div>
          <p class="eyebrow">beta access</p>
          <h2>Install OpenRemote</h2>
          <p>Beta links will live here. Until public links are ready, use local dev builds from GitHub.</p>
        </div>
        <div class="cards">
          <article id="ios-beta" class="card">
            <h3>iOS TestFlight</h3>
            <p>Join TestFlight, install OpenRemote, then connect to a computer running OpenCode with mDNS enabled.</p>
            <a class="button disabled" href="#ios-beta" aria-disabled="true">TestFlight link coming soon</a>
          </article>
          <article id="android-beta" class="card">
            <h3>Android internal testing</h3>
            <p>Join the Google Play internal testing group, install OpenRemote, then connect over LAN or mDNS.</p>
            <a class="button disabled" href="#android-beta" aria-disabled="true">Play testing link coming soon</a>
          </article>
        </div>
      </section>

      <section id="help" class="docs-section">
        <p class="eyebrow">help docs</p>
        <h2>Connect to OpenCode</h2>
        <div class="docs-grid">
          <article class="doc-card">
            <h3>Run OpenCode with mDNS</h3>
            <pre><code>opencode --mdns</code></pre>
            <p>OpenRemote searches your local network and fills connection fields when it finds a server.</p>
          </article>
          <article class="doc-card">
            <h3>Shared network password</h3>
            <pre><code>OPENCODE_SERVER_PASSWORD=changeme123 opencode --mdns</code></pre>
            <p>Use a password before starting OpenCode on shared or public Wi-Fi.</p>
          </article>
          <article class="doc-card">
            <h3>Android emulator</h3>
            <pre><code>opencode --host 0.0.0.0 --port 4096</code></pre>
            <p>From Android emulator, connect to <code>10.0.2.2:4096</code> instead of localhost.</p>
          </article>
          <article class="doc-card">
            <h3>Optional OpenCode plugin</h3>
            <pre><code>npm install opencode-openremote</code></pre>
            <p>Add <code>opencode-openremote</code> to <code>opencode.json</code> and <code>opencode-openremote/tui</code> to <code>tui.json</code> for sidebar QR and keep-awake.</p>
          </article>
        </div>
      </section>

      <footer class="footer">
        <span>OpenRemote</span>
        <a href={repoUrl}>github.com/blairhudson/openremote</a>
      </footer>
    </main>
  </body>
</html>
